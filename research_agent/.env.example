# Copy this file to .env and fill in your key(s). Never commit .env.

# --- Provider selection: "groq" (default) or "gemini" ---
LLM_PROVIDER=groq

# --- Groq (free tier): https://console.groq.com → API Keys ---
GROQ_API_KEY=gsk_your_key_here

# --- Gemini (free tier): https://aistudio.google.com/app/apikey ---
# GEMINI_API_KEY=your_gemini_key_here

# --- Optional tuning (defaults shown) ---
# GROQ_MODEL=llama-3.3-70b-versatile
# MAX_CONCURRENT_FETCHES=8
# FETCH_TIMEOUT=10
# MAX_TEXT_CHARS=4000
